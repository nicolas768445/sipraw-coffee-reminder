{
  "manifest_version": 3,
  "name": "Sipraw Coffee Break Reminder",
  "short_name": "Sipraw Breaks",
  "version": "1.0.0",
  "description": "Never miss your coffee break! Get timely reminders to sip, relax & recharge. Powered by Sipraw — premium mugs & tumblers.",
  "permissions": ["alarms", "notifications", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Sipraw Coffee Break Reminder",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
